# ---- Server ----
PORT=8787
# Public base URL of THIS backend (used to build the OAuth redirect URI).
# In local dev this is usually http://localhost:8787
PUBLIC_BASE_URL=http://localhost:8787

# ---- Discord Application (from https://discord.com/developers/applications) ----
DISCORD_CLIENT_ID=1520749743527956511
DISCORD_CLIENT_SECRET=CKYQ_n1FELfzvbs08V6qg0FRYf8e5Ebf
# Must EXACTLY match a Redirect added in the Discord app's OAuth2 settings:
#   <PUBLIC_BASE_URL>/oauth/callback
DISCORD_REDIRECT_URI=http://localhost:8787/oauth/callback
# Space-separated OAuth scopes. "identify" is required; add "email" to receive email.
DISCORD_SCOPES=identify email

# ---- Discord Webhook (the channel where code is posted) ----
# Create via: Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1520751937232830526/STZxhSAUrMZ5bcS-KhSVGhyQDTTE9MNA2FKhLsLSJgnuUO2cyOTsepd1YrUAClHEymmS

# ---- Sessions ----
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=84d63d694eccfa61b82b9a13b02c734eeca666520554504c369cd915ff0f86e70589d6f374798f169c3b538ef8c1a90e
# How long a backend session token stays valid.
SESSION_TTL=7d

# ---- Extension callback ----
# The custom URI VS Code listens on. Format: vscode://<publisher>.<extension-name>/auth
# When unsure, leave as-is; it matches this project's defaults.
EXTENSION_REDIRECT_URI=vscode://your-publisher-name.codeshare-discord/auth

# ---- CORS (optional) ----
# Comma-separated list of allowed origins for browser calls. Usually not needed
# because the VS Code extension is not a browser origin.
CORS_ORIGINS=
